<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Gradient Background for Audio Player -->
    <View
        android:id="@+id/audioBackgroundGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_audio_player"
        android:visibility="gone" />

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_buffering="when_playing"
        app:use_controller="true" />

    <LinearLayout
        android:id="@+id/audioPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <!-- Album Art Placeholder -->
        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginBottom="48dp"
            android:background="@drawable/bg_album_art_placeholder"
            android:elevation="12dp">
            
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:contentDescription="Album Art"
                android:src="@drawable/ic_placeholder_music" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/audioTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="SFTP Media Stream"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- Progress Bar -->
        <SeekBar
            android:id="@+id/audioSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progressTint="#1DB954"
            android:thumbTint="#1DB954" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/audioPosition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/audioDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/audioPlayPause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_play_pause_button"
                android:contentDescription="Play/Pause"
                android:src="@android:drawable/ic_media_pause"
                android:tint="#121212" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
